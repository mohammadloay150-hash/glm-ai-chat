{
  "functions": {
    "api/**/*.php": { "runtime": "vercel-php@0.7.5" },
    "*.php": { "runtime": "vercel-php@0.7.5" }
  },
  "rewrites": [
    { "source": "/chat", "destination": "/index.php" },
    { "source": "/models", "destination": "/index.php" },
    { "source": "/(.*)", "destination": "/index.php" }
  ]
}
